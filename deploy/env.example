# Copy to project root as `.env` for docker compose.

# Required — course / project LLM key (server-side only).
LLM_API_KEY=

# Required for Docker + Caddy deploy: same string as the password you use in the browser
# (or any long secret). Server injects it into the page; /api/* requires Bearer this token.
# Generate example:  openssl rand -hex 24
SITE_API_TOKEN=

# Optional — same as LLM if unset (neural embeddings).
# EMB_API_KEY=

# --- HTTP Basic Auth (browser login for the public URL) ---
# 1) Generate a bcrypt hash (run once):
#    docker run --rm caddy:2-alpine caddy hash-password
# 2) Paste the full bcrypt line (starts with $2a$ or $2y$) as BASIC_AUTH_HASH.
#    REQUIRED: wrap the whole hash in single quotes — otherwise Docker Compose
#    treats `$...` as variable references and your password will never work.
#    Example:  BASIC_AUTH_HASH='$2a$14$AbCdEf...fullhash...'
BASIC_AUTH_USER=admin
BASIC_AUTH_HASH=

# Host port mapped to Caddy (default 8080 → http://localhost:8080)
# PUBLIC_PORT=8080
