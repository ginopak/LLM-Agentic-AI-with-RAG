# One image: Python app + Caddy (password gate + proxy). Use this for Render/Fly/Railway public deploy.
# Local dev with compose still uses Dockerfile + docker-compose.yml.
#
# Do NOT copy Caddy from alpine — that binary is musl-linked and fails on Debian (exit 126).
# Install official linux/amd64 release (glibc), which matches python:bookworm on Render.

FROM python:3.12-slim-bookworm

ARG CADDY_VERSION=2.9.1
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl \
    && curl -fsSL \
      "https://github.com/caddyserver/caddy/releases/download/v${CADDY_VERSION}/caddy_${CADDY_VERSION}_linux_amd64.tar.gz" \
      | tar -xz -C /usr/local/bin caddy \
    && chmod +x /usr/local/bin/caddy \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY server.py retriever.py database.py ./
COPY src ./src
COPY data ./data
COPY deploy/Caddyfile.prod /etc/caddy/Caddyfile
COPY deploy/entrypoint.sh /entrypoint.sh
ENV PYTHONUNBUFFERED=1
EXPOSE 8080

# Use `sh` explicitly so deploy works even if +x or CRLF line endings break direct execution (exit 126).
ENTRYPOINT ["/bin/sh", "/entrypoint.sh"]
